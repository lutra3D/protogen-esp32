@baseUrl = http://192.168.4.1

### List all configured emotions
GET {{baseUrl}}/emotions

### Get the currently active emotion
GET {{baseUrl}}/emotion

### Create a new emotion definition
POST {{baseUrl}}/emotion
Content-Type: application/json

{
  "name": "REST Test",
  "path": "/anims/rest-test-upload.txt",
  "earColorMode": "gradient",
  "earColor": "#44AAFF",
  "gradient": {
    "from": "#44AAFF",
    "to": "#FF66CC",
    "directionX": 1.0,
    "directionY": 0.0,
    "midpoint": 0.5
  }
}

### Update an existing emotion definition
PUT {{baseUrl}}/emotion
Content-Type: application/json

{
  "name": "REST Test",
  "path": "/anims/rest-test-upload.txt",
  "earColorMode": "solid",
  "earColor": "#00FF88",
  "gradient": {
    "from": "#00FF88",
    "to": "#0044FF",
    "directionX": 0.0,
    "directionY": 1.0,
    "midpoint": 0.35
  }
}

### Change the current emotion by name
PUT {{baseUrl}}/emotion/current
Content-Type: application/x-www-form-urlencoded

name=Evil

### Delete an emotion definition by name
DELETE {{baseUrl}}/emotion?name=REST%20Test
